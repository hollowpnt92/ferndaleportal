# Shared password for extra member links (set in production)
PORTAL_PASSWORD=changeme

# Admin password for editing site content
ADMIN_PASSWORD=adminchangeme

# Session secret (use a long random string in production)
SESSION_SECRET=replace-with-random-secret

# Session cookie Secure flag: set COOKIE_SECURE=true when the site is served only over HTTPS.
# If NODE_ENV=production and you still use plain HTTP (e.g. local Docker), set COOKIE_INSECURE=true so cookies work (not recommended on the public internet).
# COOKIE_SECURE=true
# COOKIE_INSECURE=true

# Behind a reverse proxy that terminates TLS, set TRUST_PROXY=true so rate limits and req.secure behave correctly.
# TRUST_PROXY=true

# Brute-force throttling (per IP, per 15 minutes): auth POST routes vs admin JSON save
# RATE_LIMIT_AUTH_MAX=60
# RATE_LIMIT_SAVE_MAX=120
# RATE_LIMIT_POLL_MAX=40

# Site-wide gate (optional): require password before any page except /site-gate and static assets
# SITE_GATE_ENABLED=true
# SITE_GATE_PASSWORD=your-site-password

# Port inside container
PORT=3000

# --- Google Calendar (optional homepage widget) ---
# GOOGLE_CALENDAR_ID=abc123@group.calendar.google.com

# Option A — public calendar only (simple): API key from Google Cloud + calendar marked “public”
# GOOGLE_CALENDAR_API_KEY=your_api_key_here

# Option B — private calendar: service account (recommended). Calendar stays private if you only share it with the bot email.
# Create in GCP: IAM → Service accounts → create → Keys → JSON. Enable Calendar API on the project.
# In Google Calendar → Settings → Share with specific people → add the service account email (client_email in JSON) → “See all event details” or higher.
# Use ONE of these (path is easiest with Docker mount):
# GOOGLE_CALENDAR_SERVICE_ACCOUNT_PATH=/app/secrets/gcal-sa.json
# GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_CALENDAR_SERVICE_ACCOUNT_B64=(base64 of entire JSON file)

# Optional IANA zone for event display
# GOOGLE_CALENDAR_TIMEZONE=America/Detroit
