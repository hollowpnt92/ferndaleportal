<%
  var pollPalette = ['#134538', '#1a5f4a', '#2d8a6e', '#3daf8f', '#5ec9a8', '#7dceb8', '#a8e0d0'];
  var totalVotes = poll.votes.length;
  var chartSegments = [];
  var ariaParts = [];
  if (totalVotes > 0) {
    var cum = 0;
    poll.options.forEach(function (opt, idx) {
      var cnt = poll.votes.filter(function (v) { return v.optionId === opt.id; }).length;
      if (cnt > 0) {
        var pct = (cnt / totalVotes) * 100;
        var startPct = cum;
        cum += pct;
        chartSegments.push({
          color: pollPalette[idx % pollPalette.length],
          startPct: startPct,
          endPct: cum,
          label: opt.label,
          count: cnt,
        });
        ariaParts.push(opt.label + ': ' + cnt + (cnt === 1 ? ' vote' : ' votes'));
      }
    });
    if (chartSegments.length) {
      chartSegments[chartSegments.length - 1].endPct = 100;
    }
  }
  var conicParts = chartSegments.map(function (s) {
    return s.color + ' ' + s.startPct.toFixed(3) + '% ' + s.endPct.toFixed(3) + '%';
  }).join(', ');
  var chartAria = totalVotes ? ('Vote totals: ' + ariaParts.join('; ') + '. Total ' + totalVotes + ' votes.') : 'No votes yet.';
%>
<aside class="poll-sidebar poll-widget card" aria-labelledby="poll-heading">
  <header class="poll-widget-header">
    <span class="poll-widget-badge">Live poll</span>
    <h2 id="poll-heading" class="poll-widget-title">Community poll</h2>
    <p class="poll-widget-question"><%= poll.question %></p>
  </header>

  <% if (typeof pollFlash !== 'undefined' && pollFlash && pollFlash.message) { %>
    <div class="poll-alert <%= pollFlash.type === 'error' ? 'poll-alert-error' : 'poll-alert-success' %>" role="alert">
      <%= pollFlash.message %>
    </div>
  <% } %>

  <section class="poll-panel" aria-labelledby="poll-vote-label">
    <h3 id="poll-vote-label" class="poll-panel-title">Cast your vote</h3>
    <% if (!poll.options.length) { %>
      <p class="poll-muted">No choices yet — add one below.</p>
    <% } else { %>
      <form class="poll-form" method="post" action="/poll/vote">
        <div class="poll-field">
          <label for="poll-voter-name">Your name</label>
          <input type="text" id="poll-voter-name" name="voterName" required maxlength="120" autocomplete="name" placeholder="Your name">
        </div>
        <fieldset class="poll-options-fieldset">
          <legend class="poll-legend">Pick one</legend>
          <% poll.options.forEach(function (opt, oi) { %>
            <label class="poll-choice-card">
              <input type="radio" name="optionId" value="<%= opt.id %>" required>
              <span class="poll-choice-card-body">
                <span class="poll-choice-swatch" style="background-color:<%= pollPalette[oi % pollPalette.length] %>"></span>
                <span class="poll-choice-label"><%= opt.label %></span>
              </span>
            </label>
          <% }); %>
        </fieldset>
        <button type="submit" class="poll-submit">Submit vote</button>
      </form>
    <% } %>
  </section>

  <section class="poll-panel poll-panel-add" aria-labelledby="poll-add-label">
    <h3 id="poll-add-label" class="poll-panel-title">Suggest a choice</h3>
    <p class="poll-hint">Anyone can add an option - Even Jan</p>
    <form class="poll-form poll-form-inline" method="post" action="/poll/option">
      <input type="text" name="label" maxlength="200" required placeholder="New option label" aria-label="New option label">
      <button type="submit" class="poll-submit poll-submit-secondary">Add to poll</button>
    </form>
  </section>

  <section class="poll-panel poll-panel-results" aria-labelledby="poll-results-label">
    <h3 id="poll-results-label" class="poll-panel-title">Results</h3>
    <% if (!totalVotes) { %>
      <div class="poll-chart-empty">
        <div class="poll-donut poll-donut--empty" aria-hidden="true"></div>
        <p class="poll-muted">No votes yet — the chart and breakdown will show here once people vote.</p>
      </div>
    <% } else { %>
      <% if (chartSegments.length) { %>
      <div class="poll-chart-block">
        <div class="poll-donut-wrap" role="img" aria-label="<%= chartAria %>">
          <div class="poll-donut" style="background: conic-gradient(from 0deg, <%= conicParts %>);"></div>
          <div class="poll-donut-center" aria-hidden="true">
            <span class="poll-donut-total"><%= totalVotes %></span>
            <span class="poll-donut-label">votes</span>
          </div>
        </div>
        <ul class="poll-chart-legend" aria-label="Legend">
          <% chartSegments.forEach(function (seg) {
               var pct = ((seg.count / totalVotes) * 100).toFixed(0);
          %>
            <li class="poll-chart-legend-item">
              <span class="poll-chart-swatch" style="background:<%= seg.color %>"></span>
              <span class="poll-chart-legend-text">
                <span class="poll-chart-legend-label"><%= seg.label %></span>
                <span class="poll-chart-legend-meta"><%= seg.count %> · <%= pct %>%</span>
              </span>
            </li>
          <% }); %>
        </ul>
      </div>
      <% } else { %>
      <p class="poll-muted">Votes don’t match current choices. Use admin to adjust the poll or clear votes.</p>
      <% } %>

      <details class="poll-details">
        <summary>Who voted for each choice</summary>
        <ul class="poll-by-option">
          <% poll.options.forEach(function (opt) {
               var forOpt = poll.votes.filter(function (v) { return v.optionId === opt.id; });
          %>
            <li class="poll-option-block">
              <strong class="poll-option-title"><%= opt.label %></strong>
              <span class="poll-count">(<%= forOpt.length %>)</span>
              <% if (forOpt.length) { %>
                <ul class="poll-voter-names">
                  <% forOpt.forEach(function (v) { %>
                    <li><%= v.voterName %></li>
                  <% }); %>
                </ul>
              <% } %>
            </li>
          <% }); %>
        </ul>
      </details>

      <details class="poll-details">
        <summary>Vote log (newest first)</summary>
        <ol class="poll-log">
          <% poll.votes.slice().reverse().forEach(function (v) {
               var lbl = '';
               poll.options.forEach(function (o) { if (o.id === v.optionId) lbl = o.label; });
          %>
            <li>
              <span class="poll-log-name"><%= v.voterName %></span>
              <span class="poll-log-sep">→</span>
              <span class="poll-log-choice"><%= lbl || v.optionId %></span>
              <time class="poll-log-time" datetime="<%= v.createdAt %>"><%= new Date(v.createdAt).toLocaleString() %></time>
            </li>
          <% }); %>
        </ol>
      </details>
    <% } %>
  </section>
</aside>
